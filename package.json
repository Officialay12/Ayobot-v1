{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "ayobot",
  "version": "1.0.0",
  "description": "Ultimate WhatsApp Bot - Created by AYOCODES",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['auth_info','database'].forEach(f=>fs.existsSync(f)&&fs.rmSync(f,{recursive:true,force:true}));console.log('✅ Clean complete!')\"",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "pm2": "pm2 start ecosystem.config.js",
    "pm2-stop": "pm2 stop ayobot",
    "pm2-restart": "pm2 restart ayobot",
    "pm2-logs": "pm2 logs ayobot"
  },
  "keywords": [
    "whatsapp-bot",
    "baileys",
    "ayobot",
    "whatsapp",
    "bot",
    "ayocodes"
  ],
  "author": "AYOCODES",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Officialay12/Ayobot-v1.git"
  },
  "dependencies": {
    "@google/generative-ai": "^0.1.3",
    "@hapi/boom": "^10.0.1",
    "@huggingface/inference": "^2.8.1",
